<?xml version="1.0" encoding="utf-8"?>
<project>
<!-- Application Settings -->

	<!-- If you're looking for "version" I moved it to Main.hx -->
	<app title="Friday Night Funkin' (Project Roots)" file="FunkinRoots" packageName="com.funkincrew.funkin" package="com.funkincrew.funkin" main="Main" company="asmadeuxs" />

	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />

<!-- Window Settings -->

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

<!-- Path Settings -->

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bit" />

	<define name="FEATURE_MODS" if="cpp" />
	<define name="FEATURE_TRANSLATIONS" if="cpp" />

	<classpath name="source" />
	<assets path="assets"/>
	<assets path='example_mods' rename='mods' if="FEATURE_MODS" />

<!-- Libraries -->

	<haxelib name="lime" version="8.1.2"/>
	<haxelib name="openfl" version="9.3.3"/>
	<haxelib name="flixel" version="5.5.0"/>
	<haxelib name="flixel-addons" version="3.2.0"/>
	<haxelib name="flixel-ui" version="2.6.0"/>
	<haxelib name="moonchart" version="0.5.1"/>
	<haxelib name="json5hx" version="1.0.2"/>

	<!--
	These libraries are stored locally just in case
	discord_rpc is deprecated but annoying to get through things like hmm
	troll hscript is just a submodule on a locked commit in case it ever makes major breaking changes
	we will update these accordingly if need be.
	-->
	<haxelib name="hxdiscord_rpc" if="cpp" path="_dependencies/hxdiscord_rpc"/>
	<haxelib name="t-hscript" if="cpp" path="_dependencies/t-hscript"/>
	<haxedef name="hscriptPos" if="t-hscript" />

	<haxelib name="hxcpp-debug-server" if="cpp debug"/>

<!-- Haxedefines -->

	<!--Disable the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable this for Nape release builds for a serious peformance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<!--<haxedef name="message.reporting" value="pretty" />-->
</project>
