function generateNoteType(note) {
	note.loadGraphic(Paths.image('gameplay/notetypes/mine'));
	note.scale.set(3, 3);
	note.antialiasing = false;
	note.isMine = true;
	note.isFake = true; // so CPUs ignore it.
	// nerf early and late hitboxes
	note.hitMultiplier[0] = 0.8;
	note.hitMultiplier[1] = 0.8;

	note.isSustain = false;
	note.x += 50;
}
