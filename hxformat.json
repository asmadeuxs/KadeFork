{
	"lineEnds": {
		"leftCurly": "after",
		"rightCurly": "both",
		"emptyCurly": "noBreak",
		"objectLiteralCurly": {
			"leftCurly": "after"
		},
		"typedefCurly": {
			"emptyCurly": "noBreak",
			"leftCurly": "after",
			"rightCurly": "both"
		}
	},
	"indentation": {
		"character": "tab",
		"tabWidth": 2,
		"trailingWhitespace": false,
		"conditionalPolicy": "aligned",
		"indentObjectLiteral": true,
		"indentCaseLabels": true,
		"indentComplexValueExpressions": false
	},
	"sameLine": {
		"ifElse": "same",
		"doWhile": "next",
		"tryBody": "next",
		"tryCatch": "keep"
	}
}